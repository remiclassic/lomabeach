# Set to true after exporting images from AI Studio / Drive into public/images/
# (see README for the exact filenames).
VITE_USE_LOCAL_IMAGES=false

# Public site (optional overrides)
# VITE_CONTACT_EMAIL=hello@lomabeach.com
# VITE_PUBLIC_SITE_URL=https://www.lomabeach.com
# VITE_CURRENCY_SYMBOL=$
# For Thailand charges in baht via Stripe, use e.g. STRIPE_CURRENCY=thb and VITE_CURRENCY_SYMBOL=฿

# --- Stripe (set in Vercel project Environment Variables, not only in .env) ---
# Secret key — never expose to the browser. Required for /api/create-checkout-session
# STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret from Stripe Dashboard → Webhooks → your endpoint
# STRIPE_WEBHOOK_SECRET=whsec_...

# ISO currency code for Checkout (default usd)
# STRIPE_CURRENCY=usd

# Canonical site URL for success/cancel redirects (include https, no trailing slash)
# On Vercel you can omit this in production if you prefer; the API falls back to the request host.
# SITE_URL=https://www.lomabeach.com

# Optional: only needed if you add Gemini-powered features later.
# GEMINI_API_KEY=
